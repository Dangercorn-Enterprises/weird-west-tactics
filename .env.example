# Dustfall Lore Engine — environment variables
# Copy to .env

# Claude API key for AI-powered lore generation
# Without this key, fallback generators are used (still functional)
ANTHROPIC_API_KEY=your_key_here

# Model (optional — defaults to claude-opus-4-5)
# ANTHROPIC_MODEL=claude-opus-4-5

# Flask secret (optional)
# FLASK_SECRET=dustfall-ashlands-lore
